# Data source: embedded | external
# - embedded: load JSON from a path inside the app (e.g. public file)
# - external: load JSON from external URL (e.g. S3 or CDN)
VITE_DATA_SOURCE=embedded

# For embedded: path to portfolio JSON (same-origin, e.g. /data/portfolio.json)
# Used only when VITE_DATA_SOURCE=embedded
VITE_EMBEDDED_JSON_PATH=/data/portfolio.json

# For external: full URL to portfolio JSON (e.g. S3 or CDN)
# Used only when VITE_DATA_SOURCE=external
# VITE_EXTERNAL_JSON_URL=https://your-bucket.s3.amazonaws.com/portfolio.json

# Application name (used in titles). Default: Portfolio
# VITE_APP_NAME=Portfolio

# Optional debug
# VITE_APP_DEBUG=false
